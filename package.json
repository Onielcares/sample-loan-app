{
  "name": "sample-loan-app",
  "version": "1.0.0",
  "description": "Sample loan management app with TypeScript, Express, and SQLite",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "ts-node src/models/index.ts"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "dotenv": "^17.2.0",
    "express": "^4.18.2",
    "http-status-codes": "^2.3.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "pino": "^9.7.0",
    "sequelize": "^6.35.1",
    "sqlite3": "^5.1.6",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.4.2",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
